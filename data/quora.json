          "unit": "characters",
          "notes": "Short credential shown inline next to name on each answer"
        },
        {
          "name": "Full Profile Description",
          "limit": "1,000",
          "unit": "characters"
        },
        {
          "name": "Space Post",
          "limit": "No hard limit",
          "unit": "characters",
          "notes": "Posts in Spaces support rich text and embedded media"
        }
      ]
    },
    {
