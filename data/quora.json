      "priority": 1,
      "items": [
        {
          "name": "Profile Photo",
          "dimensions": "400 × 400 px recommended",
          "aspectRatio": "1:1",
          "maxFileSize": "5 MB",
          "formats": ["JPG", "PNG"],
          "notes": "Displayed as a circle; upload at 400×400 for best sharpness"
        },
        {
          "name": "Profile Header Image",
          "dimensions": "1200 × 300 px recommended",
          "aspectRatio": "4:1",
          "maxFileSize": "5 MB",
          "formats": ["JPG", "PNG"],
          "notes": "Background banner on public profile pages"
        }
      ]
    },
    {
      "category": "images",
